# Add real values to .env.local — never commit .env.local
NEXT_PUBLIC_SITE_URL=https://websolutions.zeconic.com

# Resend — contact form email delivery (resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
CONTACT_TO_EMAIL=info@zeconic.com
CONTACT_FROM_EMAIL=Zeconic Web Solutions <onboarding@resend.dev>

# Chatbase — public chatbot widget id (safe to expose to client)
NEXT_PUBLIC_CHATBASE_BOT_ID=

# Chatbase identity verification secret (server-only, for future JWT
# identify when user auth is added). Not consumed yet.
CHATBOT_IDENTITY_SECRET=
